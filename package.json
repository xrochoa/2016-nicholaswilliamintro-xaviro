{
  "name": "nickwilliam",
  "version": "1.1.0",
  "description": "Nicholas William — a 2016 ecommerce landing + shop concept (static site).",
  "private": true,
  "scripts": {
    "clean": "rimraf dist",
    "build:css": "sass src/assets/scss/style.scss:dist/assets/css/style.css src/assets/scss/shop/style.scss:dist/assets/css/shop/style.css --style=compressed --no-source-map --quiet-deps --silence-deprecation=import,slash-div,global-builtin",
    "build:assets": "node scripts/build.js",
    "build": "npm run clean && npm run build:css && npm run build:assets",
    "watch:css": "sass --watch src/assets/scss/style.scss:dist/assets/css/style.css src/assets/scss/shop/style.scss:dist/assets/css/shop/style.css --style=expanded",
    "dev": "npm run build && http-server dist -p 4000 -c-1 -o",
    "start": "http-server dist -p 4000 -c-1"
  },
  "author": "Xavier Reyes Ochoa <xareyesochoa@gmail.com> (http://www.xaviro.com)",
  "license": "MIT",
  "devDependencies": {
    "http-server": "^14.1.1",
    "rimraf": "^5.0.5",
    "sass": "^1.77.0"
  }
}
